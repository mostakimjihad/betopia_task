<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="current_password_view_form" model="ir.ui.view">
        <field name="model">res.users.identitycheck</field>
        <field name="inherit_id" ref="base.res_users_identitycheck_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='password']" position="after">
                <br/>
                <field class="o_field_highlight col-10 col-md-6 px-0" name="confirm_password" autocomplete="current-password"
                                    required="auth_method == 'password'" password="True" placeholder="Confirm your Current Password"/>
            </xpath>
        </field>
    </record>
</odoo>
